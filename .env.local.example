# BASE_URL="https://mycustomdomain.com"
BETTER_AUTH_SECRET="random-string-of-characters"
CRYPTO_KEY="random-string-of-characters"
GITHUB_APP_ID="your-github-app-id"
GITHUB_APP_NAME="your-github-app-machine-name"
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
xxx
-----END RSA PRIVATE KEY-----"
GITHUB_APP_WEBHOOK_SECRET="another-random-string-of-characters"
GITHUB_APP_CLIENT_ID="your-github-app-client-id"
GITHUB_APP_CLIENT_SECRET="your-github-app-client-secret"
# EMAIL_PROVIDER="resend" # or "postmark" or "smtp"
EMAIL_FROM="Interleaved <no-reply@example.com>"
# Resend config
# RESEND_API_KEY="your-resend-api-key"
# Postmark config
# POSTMARK_SERVER_TOKEN="your-server-token"
# POSTMARK_MESSAGE_STREAM="outbound"  # optional, defaults to "outbound"
# SMTP config
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="smtp-user"
# SMTP_PASSWORD="smtp-password"
DATABASE_URL="postgresql://interleaved:interleaved@localhost:5432/interleaved"
# CACHE_CHECK_MIN=5
# CONFIG_CHECK_MIN=5
# FILE_TTL_MIN=1440
# PERMISSIONS_TTL_MIN=60
# BRANCH_HEAD_TTL_MS=15000
# REPO_META_TTL_MS=15000
# Webhook push processing thresholds
# <= WEBHOOK_PUSH_INCREMENTAL_MAX_FILES: incremental cache updates
# > WEBHOOK_PUSH_INCREMENTAL_MAX_FILES and <= WEBHOOK_PUSH_SCOPED_INVALIDATION_MAX_FILES: scoped cache invalidation
# > WEBHOOK_PUSH_SCOPED_INVALIDATION_MAX_FILES: full branch cache invalidation
# WEBHOOK_PUSH_INCREMENTAL_MAX_FILES=120
# WEBHOOK_PUSH_SCOPED_INVALIDATION_MAX_FILES=800

# --- Rate Limiting ---
# RATE_LIMIT_MAX=120              # Max requests per window per IP
# RATE_LIMIT_WINDOW_MS=60000      # Window duration in ms

# --- Sentry (optional) ---
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# --- External Media Storage (optional) ---
# Set MEDIA_S3_BUCKET to enable S3/R2 storage for user-uploaded media.
# Theme/template assets in git are unaffected.
# MEDIA_S3_BUCKET="my-media-bucket"
# MEDIA_S3_REGION="auto"                            # "auto" for Cloudflare R2
# MEDIA_S3_ENDPOINT="https://xxx.r2.cloudflarestorage.com"  # R2/MinIO endpoint
# MEDIA_S3_ACCESS_KEY_ID="your-access-key"
# MEDIA_S3_SECRET_ACCESS_KEY="your-secret-key"
# MEDIA_PUBLIC_URL="https://cdn.example.com"        # CDN or Imageflow server URL
# When MEDIA_PUBLIC_URL points to an Imageflow server, images support
# RIAPI query-string transforms: ?w=800&h=600&mode=crop&format=webp
